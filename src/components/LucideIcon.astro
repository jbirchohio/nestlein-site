---
export interface Props {
  name: string;
  className?: string;
  size?: number;
}

const { name, className = "w-5 h-5 text-orange-600", size = 20 } = Astro.props;
const iconPath = `/node_modules/lucide-static/icons/${name}.svg`;
---

{Astro.fetch(iconPath).then((res) => res.text()).then((svg) =>
  svg
    .replace('<svg', `<svg class="${className}" width="${size}" height="${size}"`)
    .replace(/stroke-width="\d+"/, 'stroke-width="1.5"')
    .replace(/\s+/g, ' ') /* optional: remove extra whitespace */
)}
