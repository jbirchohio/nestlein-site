import "../styles/tailwind.css";
import { getCollection } from 'astro:content';

const locations = await getCollection('locations');

const groupedLocations = locations.map(loc => ({
  ...loc.data,
  slug: loc.slug
}));

const safeJson = JSON.stringify(groupedLocations).replace(/</g, '\u003c');

---

<html>
  <head>
    <title>NestleIn</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
  </head>
  <body class="bg-orange-50 font-sans">
    <!-- Header -->
    <header class="sticky top-0 z-50 bg-white shadow-sm p-4 flex flex-col md:flex-row items-center justify-between gap-2">
      <div class="text-2xl font-bold text-orange-600">NestleIn</div>
      <input id="search" placeholder="Search spots or tags..." class="border border-orange-300 px-4 py-2 rounded-full shadow-sm focus:ring-2 focus:ring-orange-400 w-full max-w-sm">
      <select id="distance-filter" class="border border-orange-300 px-3 py-2 rounded-full text-sm">
        <option value="5">Within 5 mi</option>
        <option value="10">Within 10 mi</option>
        <option value="25">Within 25 mi</option>
        <option value="50">Within 50 mi</option>
      </select>
    </header>

    <!-- Tag Filter Bar -->
    <div id="tag-filters" class="w-full max-w-4xl mx-auto mt-4 flex overflow-x-auto gap-2 py-2 px-2"></div>

    <!-- Hero Section -->
    <section class="bg-gradient-to-r from-orange-100 to-orange-50 py-16 text-center">
      <h1 class="text-4xl font-extrabold text-orange-700 mb-2">Work Remotely. Nest Comfortably.</h1>
      <p class="text-gray-700 text-lg max-w-xl mx-auto">Discover the best spots with Wi-Fi, vibes, and space to get things done.</p>
      <div class="mt-6 flex flex-wrap justify-center gap-2">
        <span class="bg-white border border-orange-300 text-orange-600 px-4 py-1 rounded-full text-sm">✨ Cozy Corners</span>
        <span class="bg-white border border-orange-300 text-orange-600 px-4 py-1 rounded-full text-sm">🔌 Lots of Outlets</span>
        <span class="bg-white border border-orange-300 text-orange-600 px-4 py-1 rounded-full text-sm">☕ Top Coffee</span>
      </div>
    </section>

    <!-- Main Content -->
    <main class="px-4 py-10 space-y-12">
      <div id="dynamic-sections"></div>
    </main>

    <script type="application/json" id="location-data" set:html={safeJson}></script>

    <script>
      document.addEventListener("DOMContentLoaded", () => {
        const locations = JSON.parse(document.getElementById("location-data").textContent);
        const sectionContainer = document.getElementById("dynamic-sections");
        const search = document.getElementById("search");
        const distanceSelect = document.getElementById("distance-filter");

        let userLat = null, userLon = null;

        const savedDistance = localStorage.getItem("nestlein-distance");
        if (savedDistance) distanceSelect.value = savedDistance;

        const savedSearch = localStorage.getItem("nestlein-search");
        if (savedSearch) search.value = savedSearch;

        function haversine(lat1, lon1, lat2, lon2) {
          const toRad = angle => angle * Math.PI / 180;
          const R = 6371;
          const dLat = toRad(lat2 - lat1);
          const dLon = toRad(lon2 - lon1);
          const a = Math.sin(dLat / 2) ** 2 + Math.cos(toRad(lat1)) * Math.cos(toRad(lat2)) * Math.sin(dLon / 2) ** 2;
          const c = 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1 - a));
          return R * c * 0.621371;
        }

        function createTagFilters(allTags) {
          const container = document.getElementById("tag-filters");
          container.innerHTML = "";

          const sortedTags = [...new Set(allTags)].sort();
          sortedTags.forEach(tag => {
            const btn = document.createElement("button");
            btn.textContent = tag;
            btn.className = "bg-orange-100 text-orange-700 text-xs px-3 py-1 rounded-full whitespace-nowrap hover:bg-orange-200 transition";
            btn.addEventListener("click", () => {
              search.value = tag;
              localStorage.setItem("nestlein-search", tag);
              filter();
            });
            container.appendChild(btn);
          });
        }

        function renderSections() {
          sectionContainer.innerHTML = "";

          const allTags = [...new Set(locations.flatMap(l => l.tags || []))];
          const shuffledTags = allTags.sort(() => 0.5 - Math.random()).slice(0, 3);
          createTagFilters(allTags);

          let lat = parseFloat(new URL(window.location.href).searchParams.get("lat")) || userLat;
          let lon = parseFloat(new URL(window.location.href).searchParams.get("lon")) || userLon;

          shuffledTags.forEach(tag => {
            const filtered = locations.filter(l => (l.tags || []).includes(tag));
            const nearby = filtered
              .filter(l => l.latitude && l.longitude)
              .map(l => ({
                ...l,
                distance: lat && lon ? haversine(lat, lon, l.latitude, l.longitude) : Infinity
              }))
              .sort((a, b) => a.distance - b.distance)
              .slice(0, 3);

            if (!nearby.length) return;

            const section = document.createElement("section");
            section.innerHTML = `
              <h2 class="text-2xl font-semibold text-orange-700 mb-4">${tag}</h2>
              <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-4">
                ${nearby.map(loc => `
                  <a href="/locations/${loc.slug}" class="block bg-white rounded-xl shadow hover:shadow-md transition p-4 border border-orange-100 w-full max-w-sm mx-auto location-card" data-tags="${(loc.tags || []).join(', ').toLowerCase()}" data-lat="${loc.latitude}" data-lon="${loc.longitude}">
                    ${loc.logo_url ? `<img src="${loc.logo_url}" alt="${loc.name}" class="w-full h-40 object-cover rounded-md mb-3">` : ""}
                    <h3 class="text-lg font-semibold text-orange-800 mb-1">${loc.name}</h3>
                    <p class="text-sm text-gray-500">${loc.address || ""}</p>
                    ${isFinite(loc.distance) ? `<p class="text-xs text-gray-600 mt-1">📍 ${loc.distance.toFixed(1)} mi away</p>` : ""}
                    <p class="text-sm mt-1">⭐ ${loc.restaurant_score || 0}/10</p>
                    <p class="text-sm">🧠 ${loc.best_time_to_work_remotely || ""}</p>
                    <div class="mt-2 flex flex-wrap gap-1">
                      ${(loc.tags || []).map(t => `<span class="text-xs bg-orange-100 text-orange-700 px-2 py-0.5 rounded-full">${t}</span>`).join("")}
                    </div>
                    ${loc.latitude && loc.longitude ? `<div class="mt-2"><a href="https://www.google.com/maps/search/?api=1&query=${loc.latitude},${loc.longitude}" target="_blank" class="text-xs underline text-orange-600">Map</a></div>` : ""}
                  </a>
                `).join("")}
              </div>
            `;
            sectionContainer.appendChild(section);
          });

          filter();
        }

        function filter() {
          const q = search.value.toLowerCase();
          const maxDistance = parseInt(distanceSelect.value);
          localStorage.setItem("nestlein-distance", distanceSelect.value);
          localStorage.setItem("nestlein-search", search.value);

          const lat = parseFloat(new URL(window.location.href).searchParams.get("lat")) || userLat;
          const lon = parseFloat(new URL(window.location.href).searchParams.get("lon")) || userLon;

          document.querySelectorAll(".location-card").forEach(card => {
            const name = card.querySelector("h3")?.textContent?.toLowerCase() || "";
            const tags = card.dataset.tags || "";
            const matchText = name.includes(q) || tags.includes(q);

            const cardLat = parseFloat(card.dataset.lat);
            const cardLon = parseFloat(card.dataset.lon);
            const dist = lat && lon && cardLat && cardLon ? haversine(lat, lon, cardLat, cardLon) : 0;

            card.style.display = matchText && dist <= maxDistance ? "block" : "none";
          });
        }

        search.addEventListener("input", filter);
        distanceSelect.addEventListener("change", filter);

        if (navigator.geolocation && !window.location.search.includes("lat")) {
          navigator.geolocation.getCurrentPosition(pos => {
            userLat = pos.coords.latitude;
            userLon = pos.coords.longitude;
            renderSections();
          });
        } else {
          renderSections();
        }
      });
    </script>
  </body>
</html>
