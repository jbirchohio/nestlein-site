---
import "../styles/tailwind.css";
import { getCollection } from 'astro:content';

const locations = await getCollection('locations');

function haversineDistance(lat1, lon1, lat2, lon2) {
  const toRad = angle => (angle * Math.PI) / 180;
  const R = 6371;
  const dLat = toRad(lat2 - lat1);
  const dLon = toRad(lon2 - lon1);
  const a = Math.sin(dLat / 2) ** 2 + Math.cos(toRad(lat1)) * Math.cos(toRad(lat2)) * Math.sin(dLon / 2) ** 2;
  const c = 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1 - a));
  return R * c * 0.621371;
}

const userLat = Number(Astro.url.searchParams.get('lat')) || null;
const userLon = Number(Astro.url.searchParams.get('lon')) || null;
const defaultRadius = Number(Astro.url.searchParams.get('radius')) || 10;

const locationsWithDistance = userLat && userLon
  ? locations.map(loc => {
      const { latitude, longitude } = loc.data;
      const distance = (latitude && longitude)
        ? haversineDistance(userLat, userLon, latitude, longitude)
        : Infinity;
      return { ...loc, distance };
    }).sort((a, b) => a.distance - b.distance)
  : locations;

const pageSize = 9;
const totalPages = Math.ceil(locationsWithDistance.length / pageSize);
const currentPage = Number(Astro.url.searchParams.get('page') || '1');
const paginatedLocations = locationsWithDistance.slice((currentPage - 1) * pageSize, currentPage * pageSize);

const allTags = ["Open", "Fast Wi-Fi", "Family-Friendly", "Vegan Options", "Pet-Friendly", "Study Spot"];
const shuffledTags = allTags.sort(() => Math.random() - 0.5);
const tagSections = shuffledTags.slice(0, 3);
---

<html>
  <head>
    <title>NestleIn - Remote-Friendly Spots</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
  </head>
  <body class="bg-gradient-to-b from-orange-50 to-white font-sans">
    <header class="sticky top-0 bg-white shadow z-10 p-6 flex flex-col items-center gap-2">
      <div class="text-3xl font-extrabold text-orange-600 tracking-wide">NestleIn</div>
      <input id="search" type="text" placeholder="Search by name or tag..." class="border border-orange-300 px-4 py-2 w-full max-w-md rounded-full shadow-sm focus:outline-none focus:ring-2 focus:ring-orange-400">
      <select id="distance-filter" class="mt-2 border border-orange-300 px-3 py-1 rounded-full text-sm shadow-sm focus:outline-none focus:ring-1 focus:ring-orange-300">
        <option value="5">Within 5 mi</option>
        <option value="10" selected>Within 10 mi</option>
        <option value="25">Within 25 mi</option>
        <option value="50">Within 50 mi</option>
      </select>
    </header>

    <main class="px-4 py-6">
      {tagSections.map(tag => {
        const group = paginatedLocations.filter(({ data }) => data.tags.includes(tag));
        return (
          <section class="mb-12">
            <h2 class="text-xl font-semibold text-orange-600 mb-4 px-2">{tag}</h2>
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
              {group.map(({ data, distance }) => (
                <a href={`/locations/${data.slug}`} class="block bg-white rounded-lg border border-orange-200 shadow hover:shadow-md transition overflow-hidden location-card text-sm w-full max-w-[225px] mx-auto" data-tags={`Tags: ${data.tags.join(', ')}`} data-lat={data.latitude} data-lon={data.longitude}>
                  {data.logo_url && <img src={data.logo_url} alt={`${data.name} logo`} class="w-full h-24 object-cover border-b border-orange-100" />}
                  <div class="p-3">
                    <h3 class="text-base font-semibold text-orange-700 mb-1">{data.name}</h3>
                    <p class="text-xs text-gray-600 location-address">{data.address}</p>
                    <p class="mt-1 text-xs text-gray-700 font-medium">⭐ {data.restaurant_score}/10</p>
                    <p class="text-xs text-gray-700">🧠 {data.best_time_to_work_remotely}</p>
                    {distance !== undefined && isFinite(distance) && <p class="text-xs text-gray-500">📍 {distance.toFixed(1)} mi away</p>}
                    <div class="mt-2 flex flex-wrap gap-1">
                      {data.tags.map(tag => <span class="text-[10px] bg-orange-100 text-orange-700 px-2 py-0.5 rounded-full">{tag}</span>)}
                    </div>
                  </div>
                </a>
              ))}
            </div>
          </section>
        );
      })}

      <div class="mt-10 flex justify-center gap-2">
        {Array.from({ length: totalPages }).map((_, i) => (
          <a href={`/?page=${i + 1}`} class={`px-3 py-1 rounded-full ${currentPage === i + 1 ? 'bg-orange-500 text-white' : 'bg-gray-200 text-gray-800'}`}>{i + 1}</a>
        ))}
      </div>
    </main>

    <script>
      const search = document.getElementById('search');
      const cards = document.querySelectorAll('.location-card');
      const distanceSelect = document.getElementById('distance-filter');

      function haversine(lat1, lon1, lat2, lon2) {
        const toRad = angle => angle * Math.PI / 180;
        const R = 6371;
        const dLat = toRad(lat2 - lat1);
        const dLon = toRad(lon2 - lon1);
        const a = Math.sin(dLat / 2) ** 2 + Math.cos(toRad(lat1)) * Math.cos(toRad(lat2)) * Math.sin(dLon / 2) ** 2;
        const c = 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1 - a));
        return R * c * 0.621371;
      }

      function filter() {
        const q = search.value.toLowerCase();
        const maxDistance = parseInt(distanceSelect.value);
        const url = new URL(window.location.href);
        const lat = parseFloat(url.searchParams.get('lat'));
        const lon = parseFloat(url.searchParams.get('lon'));

        cards.forEach(card => {
          const name = card.querySelector('h3')?.textContent?.toLowerCase() || '';
          const tags = card.dataset.tags?.toLowerCase() || '';
          const matchText = name.includes(q) || tags.includes(q);

          const cardLat = parseFloat(card.dataset.lat);
          const cardLon = parseFloat(card.dataset.lon);
          const matchDistance = (lat && lon && cardLat && cardLon)
            ? haversine(lat, lon, cardLat, cardLon) <= maxDistance
            : true;

          card.style.display = matchText && matchDistance ? 'block' : 'none';
        });
      }

      search.addEventListener('input', filter);
      distanceSelect.addEventListener('change', filter);

      if (navigator.geolocation && !window.location.search.includes("lat") && !window.location.search.includes("lon")) {
        navigator.geolocation.getCurrentPosition(function(position) {
          const url = new URL(window.location.href);
          url.searchParams.set('lat', position.coords.latitude);
          url.searchParams.set('lon', position.coords.longitude);
          window.location.href = url.toString();
        });
      }
    </script>
  </body>
</html>
