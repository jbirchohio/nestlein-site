---
// Load locations and prep JSON
import "../styles/tailwind.css";
import { getCollection } from 'astro:content';
import LucideIcon from "../components/LucideIcon.jsx";

const locations = await getCollection('locations');

const groupedLocations = locations.map(loc => ({
  ...loc.data,
  slug: loc.slug
}));

const safeJson = JSON.stringify(groupedLocations).replace(/</g, '\u003c');
---

<html>
  <head>
    <title>NestleIn</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;700&display=swap" rel="stylesheet">
  </head>

  <body class="bg-orange-50 font-sans">
    <!-- Header -->
    <header class="sticky top-0 z-50 bg-white shadow-sm p-4 flex flex-col md:flex-row items-center justify-between gap-2">
      <div class="text-2xl font-bold text-orange-600">NestleIn</div>
      <input id="search" placeholder="Search spots or tags..." class="border border-orange-300 px-4 py-2 rounded-full shadow-sm focus:ring-2 focus:ring-orange-400 w-full max-w-sm">
      <select id="distance-filter" class="border border-orange-300 px-3 py-2 rounded-full text-sm">
        <option value="5">Within 5 mi</option>
        <option value="10">Within 10 mi</option>
        <option value="25">Within 25 mi</option>
        <option value="50">Within 50 mi</option>
      </select>
    </header>

    <!-- Hero Section -->
    <section class="bg-gradient-to-r from-orange-100 to-orange-50 py-16 text-center">
      <h1 class="text-4xl font-extrabold text-orange-700 mb-2">Work Remotely. Nest Comfortably.</h1>
      <p class="text-gray-700 text-lg max-w-xl mx-auto">Discover the best spots with Wi-Fi, vibes, and space to get things done.</p>
      <div id="tag-pills" class="mt-6 flex flex-wrap justify-center gap-2"></div>
    </section>

    <!-- Main Content -->
    <main class="px-4 py-10">
      <div id="dynamic-sections" class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-6"></div>
    </main>

    <!-- Data Injection -->
    <script type="application/json" id="location-data" set:html={safeJson}></script>
    <script src="https://cdn.jsdelivr.net/npm/fuse.js@7.1.0"></script>

    <!-- Scripts -->
    <script type="module">
      import { createElement as h } from "https://esm.sh/react";
      import { render } from "https://esm.sh/react-dom";
      import { Star, BrainCog, Clock } from "https://esm.sh/lucide-react";

      document.addEventListener("DOMContentLoaded", () => {
        const locations = JSON.parse(document.getElementById("location-data").textContent);
        const container = document.getElementById("dynamic-sections");
        const search = document.getElementById("search");
        const distanceSelect = document.getElementById("distance-filter");
        const pillContainer = document.getElementById("tag-pills");

        const fuse = new window.Fuse(locations, {
          keys: ['name', 'tags', 'address'],
          threshold: 0.35,
        });

        const isTouch = 'ontouchstart' in window || navigator.maxTouchPoints > 0;

        function renderCards(data) {
          container.innerHTML = data.map(loc => {
            return `
              <div class="group perspective">
                <div class="relative w-full h-full transform-style-preserve-3d transition duration-500 group-hover:rotate-y-180 ${
                  isTouch ? 'tap-flip' : ''
                } rounded-xl shadow border border-orange-100 bg-white">
                  <!-- Front -->
                  <div class="absolute inset-0 backface-hidden rounded-xl overflow-hidden">
                    ${loc.logo_url ? `<img src="${loc.logo_url}" alt="${loc.name}" class="w-full h-40 object-cover">` : ""}
                    <div class="p-4">
                      <h3 class="text-lg font-bold text-orange-800">${loc.name}</h3>
                      <div class="absolute bottom-2 right-2 text-xs bg-white/80 px-3 py-1 rounded-full border border-orange-200 font-semibold shadow" title="${loc.hours_of_operation || 'Hours unknown'}">
                        ${loc.hours_of_operation?.toLowerCase().includes('closed') ? '🔴 Closed' : '🟢 Open'}
                      </div>
                    </div>
                  </div>

                  <!-- Back -->
                  <div class="absolute inset-0 backface-hidden rotate-y-180 p-4 rounded-xl bg-orange-50 flex flex-col justify-center space-y-2 text-sm text-gray-800">
                    <p class="text-gray-600 text-sm">${loc.address || ""}</p>
                    <p class="flex items-center gap-2">
                      <span class="icon"><svg class="w-4 h-4 text-yellow-500" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M12 2l2.9 6.26L22 9.27l-5.5 5.36L18.8 22 12 18.27 5.2 22l1.3-7.37L1 9.27l7.1-1.01L12 2z"/></svg></span>
                      <strong>${loc.restaurant_score || 0}/10</strong>
                    </p>
                    <p class="flex items-center gap-2">
                      <span class="icon"><svg class="w-4 h-4 text-orange-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M12 12c2.21 0 4-1.79 4-4S14.21 4 12 4 8 5.79 8 8s1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/></svg></span>
                      ${loc.best_time_to_work_remotely || ''}
                    </p>
                    <div class="flex flex-wrap gap-1">
                      ${(loc.tags || []).map(t => `<span class="text-xs bg-orange-100 text-orange-700 px-2 py-0.5 rounded-full">${t}</span>`).join("")}
                    </div>
                    <a href="/locations/${loc.slug}" class="text-orange-700 underline text-xs mt-2">View Details</a>
                  </div>
                </div>
              </div>
            `;
          }).join("");

          if (isTouch) {
            document.querySelectorAll(".tap-flip").forEach(el => {
              el.addEventListener("click", () => {
                el.classList.toggle("rotate-y-180");
              });
            });
          }
        }

        function filter() {
          const q = search.value.trim();
          const maxDist = parseInt(distanceSelect.value);
          let results = q ? fuse.search(q).map(r => r.item) : locations;
          renderCards(results);
        }

        const allTags = [...new Set(locations.flatMap(l => l.tags || []))];
        const random = allTags.sort(() => 0.5 - Math.random()).slice(0, 3);
        pillContainer.innerHTML = random.map(tag => `<button class="tag-pill bg-white border border-orange-300 text-orange-600 px-4 py-1 rounded-full text-sm hover:bg-orange-200 transition" data-tag="${tag}">${tag}</button>`).join("");

        pillContainer.querySelectorAll(".tag-pill").forEach(button => {
          button.addEventListener("click", () => {
            const tag = button.dataset.tag;
            search.value = tag;
            filter();
          });
        });

        search.addEventListener("input", filter);
        distanceSelect.addEventListener("change", filter);
        filter();
      });
    </script>

    <style>
      .perspective { perspective: 1000px; }
      .transform-style-preserve-3d { transform-style: preserve-3d; }
      .backface-hidden { backface-visibility: hidden; transform: rotateY(0); }
      .rotate-y-180 { transform: rotateY(180deg); }
    </style>
  </body>
</html>
