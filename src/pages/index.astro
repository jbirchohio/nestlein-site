---
// 🧠 Astro content loading
import "../styles/tailwind.css";
import { getCollection } from 'astro:content';

const locations = await getCollection('locations');

const groupedLocations = locations.map(loc => ({
  ...loc.data,
  slug: loc.slug
}));

const safeJson = JSON.stringify(groupedLocations).replace(/</g, '\u003c');
---

<html>
  <head>
    <title>NestleIn</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;700&display=swap" rel="stylesheet">
  </head>

  <body class="bg-orange-50 font-sans">
    <!-- Header -->
    <header class="sticky top-0 z-50 bg-white shadow-sm p-4 flex flex-col md:flex-row items-center justify-between gap-2">
      <div class="text-2xl font-bold text-orange-600">NestleIn</div>
      <input id="search" placeholder="Search spots or tags..." class="border border-orange-300 px-4 py-2 rounded-full shadow-sm focus:ring-2 focus:ring-orange-400 w-full max-w-sm">
      <select id="distance-filter" class="border border-orange-300 px-3 py-2 rounded-full text-sm">
        <option value="5">Within 5 mi</option>
        <option value="10">Within 10 mi</option>
        <option value="25">Within 25 mi</option>
        <option value="50">Within 50 mi</option>
        <option value="0">Ignore distance</option>
      </select>
    </header>

    <!-- Hero Section -->
    <section class="bg-gradient-to-r from-orange-100 to-orange-50 py-16 text-center">
      <h1 class="text-4xl font-extrabold text-orange-700 mb-2">Work Remotely. Nest Comfortably.</h1>
      <p class="text-gray-700 text-lg max-w-xl mx-auto">Discover the best spots with Wi-Fi, vibes, and space to get things done.</p>
      <div id="tag-pills" class="mt-6 flex flex-wrap justify-center gap-2 transition-all duration-500 opacity-0 translate-y-2"></div>
    </section>

    <!-- Main Content -->
    <main class="px-4 py-10 space-y-12">
      <div id="dynamic-sections"></div>
    </main>

    <!-- Data + Fuse -->
    <script type="application/json" id="location-data" set:html={safeJson}></script>
    <script src="https://cdn.jsdelivr.net/npm/fuse.js@7.1.0/dist/fuse.min.js"></script>

    <script>
      document.addEventListener("DOMContentLoaded", () => {
        const locations = JSON.parse(document.getElementById("location-data").textContent);
        const sectionContainer = document.getElementById("dynamic-sections");
        const search = document.getElementById("search");
        const distanceSelect = document.getElementById("distance-filter");
        const pillContainer = document.getElementById("tag-pills");

        const savedDistance = localStorage.getItem("nestlein-distance");
        if (savedDistance) distanceSelect.value = savedDistance;
        const savedSearch = localStorage.getItem("nestlein-search");
        if (savedSearch) search.value = savedSearch;

        const fuse = new window.Fuse(locations, {
          keys: ['name', 'tags', 'address'],
          threshold: 0.35,
          includeScore: true,
        });

        function renderCards(data) {
          const now = new Date();
          const currentDay = now.toLocaleDateString('en-US', { weekday: 'long' });
          const currentTime = now.getHours() + now.getMinutes() / 60;

          const html = data.map(loc => {
            const status = getOpenStatus(loc.hours_of_operation, currentDay, currentTime);

            return `
              <a href="/locations/${loc.slug}" class="group relative block bg-white rounded-xl shadow hover:shadow-lg transition border border-orange-100 w-full max-w-sm mx-auto overflow-hidden">
                <div class="relative">
                  <img src="${loc.logo_url}" alt="${loc.name}" class="w-full h-40 object-cover rounded-t-md">
                  <div class="absolute bottom-2 right-2 bg-white/90 text-xs font-semibold rounded-full px-3 py-0.5 shadow border ${
                    status.status === 'open' ? 'text-green-600 border-green-300' : 'text-red-600 border-red-300'
                  }">
                    ${status.status === 'open' ? '🟢' : '🔴'} ${status.text}
                  </div>
                </div>
                <div class="p-4">
                  <h3 class="text-lg font-semibold text-orange-800">${loc.name}</h3>
                  <div class="transition-all duration-300 opacity-0 max-h-0 group-hover:opacity-100 group-hover:max-h-96 overflow-hidden space-y-1 mt-2">
                    <p class="text-sm text-gray-500">${loc.address || ""}</p>
                    <p class="text-sm">⭐ ${loc.restaurant_score || 0}/10</p>
                    <p class="text-sm">🧠 ${loc.best_time_to_work_remotely || ""}</p>
                    <div class="flex flex-wrap gap-1 mt-2">
                      ${(loc.tags || []).map(t => `<span class="text-xs bg-orange-100 text-orange-700 px-2 py-0.5 rounded-full">${t}</span>`).join("")}
                    </div>
                  </div>
                </div>
              </a>
            `;
          }).join("");

          sectionContainer.innerHTML = `<div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-4">${html}</div>`;
        }

        function getOpenStatus(hoursStr, day, nowDecimal) {
          if (!hoursStr || !isDayCovered(hoursStr, day)) return { status: 'unknown', text: 'Unknown hours' };
          const match = hoursStr.match(/(\d{1,2})(?::(\d{2}))?\s*(AM|PM)?\s*(?:to|-)\s*(\d{1,2})(?::(\d{2}))?\s*(AM|PM)?/i);
          if (!match) return { status: 'unknown', text: 'Unknown hours' };
          const [_, h1, m1 = '0', ampm1 = '', h2, m2 = '0', ampm2 = ''] = match;
          const open = to24Hour(+h1, +m1, ampm1);
          const close = to24Hour(+h2, +m2, ampm2);
          return nowDecimal >= open && nowDecimal <= close
            ? { status: 'open', text: `Open until ${formatTime(close)}` }
            : { status: 'closed', text: `Opens at ${formatTime(open)}` };
        }

        function isDayCovered(str, day) {
          const lc = str.toLowerCase();
          const weekdays = ['monday','tuesday','wednesday','thursday','friday'];
          const weekends = ['saturday','sunday'];
          return lc.includes(day.toLowerCase()) ||
                 lc.includes('every day') || lc.includes('daily') ||
                 lc.includes('monday through sunday') || lc.includes('monday - sunday') ||
                 (lc.includes('weekdays') && weekdays.includes(day.toLowerCase())) ||
                 (lc.includes('weekends') && weekends.includes(day.toLowerCase())) ||
                 (lc.includes('mon–fri') && weekdays.includes(day.toLowerCase())) ||
                 (lc.includes('fri–sun') && ['friday','saturday','sunday'].includes(day.toLowerCase()));
        }

        function to24Hour(hour, minute, ampm) {
          if (!ampm) return hour + minute / 60;
          const h = ampm.toUpperCase() === 'PM' && hour !== 12 ? hour + 12 : hour === 12 && ampm.toUpperCase() === 'AM' ? 0 : hour;
          return h + minute / 60;
        }

        function formatTime(decimalTime) {
          const h = Math.floor(decimalTime);
          const m = Math.round((decimalTime - h) * 60);
          const ampm = h >= 12 ? 'PM' : 'AM';
          const displayHour = ((h + 11) % 12 + 1);
          return `${displayHour}${m > 0 ? ':' + String(m).padStart(2, '0') : ''} ${ampm}`;
        }

        function filter() {
          const query = search.value.trim();
          const maxDistance = parseInt(distanceSelect.value);
          localStorage.setItem("nestlein-search", query);
          localStorage.setItem("nestlein-distance", distanceSelect.value);

          let results = query ? fuse.search(query).map(r => r.item) : locations;

          if (maxDistance > 0 && navigator.geolocation) {
            navigator.geolocation.getCurrentPosition(pos => {
              const { latitude, longitude } = pos.coords;
              results = results.filter(loc => {
                if (!loc.latitude || !loc.longitude) return false;
                const dist = haversine(latitude, longitude, loc.latitude, loc.longitude);
                return dist <= maxDistance;
              });
              renderCards(results);
            });
          } else {
            renderCards(results);
          }
        }

        function haversine(lat1, lon1, lat2, lon2) {
          const toRad = angle => angle * Math.PI / 180;
          const R = 6371;
          const dLat = toRad(lat2 - lat1);
          const dLon = toRad(lon2 - lon1);
          const a = Math.sin(dLat / 2) ** 2 + Math.cos(toRad(lat1)) * Math.cos(toRad(lat2)) * Math.sin(dLon / 2) ** 2;
          const c = 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1 - a));
          return R * c * 0.621371;
        }

        const tagSet = new Set();
        locations.forEach(loc => (loc.tags || []).forEach(tag => tagSet.add(tag)));
        const allTags = Array.from(tagSet);
        const randomTags = allTags.sort(() => 0.5 - Math.random()).slice(0, 3);

        pillContainer.innerHTML = randomTags.map(tag => `
          <button class="tag-pill bg-white border border-orange-300 text-orange-600 px-4 py-1 rounded-full text-sm hover:bg-orange-200 transition" data-tag="${tag}">
            ${tag}
          </button>
        `).join("");

        setTimeout(() => {
          pillContainer.classList.remove("opacity-0", "translate-y-2");
        }, 100);

        let activeTag = null;

        pillContainer.querySelectorAll(".tag-pill").forEach(button => {
          button.addEventListener("click", () => {
            const tag = button.getAttribute("data-tag");
            activeTag = activeTag === tag ? null : tag;
            search.value = activeTag || "";
            pillContainer.querySelectorAll(".tag-pill").forEach(btn => {
              btn.classList.remove("bg-orange-600", "text-white", "shadow");
              btn.classList.add("bg-white", "text-orange-600", "border-orange-300");
            });
            if (activeTag) {
              button.classList.remove("bg-white", "text-orange-600", "border-orange-300");
              button.classList.add("bg-orange-600", "text-white", "shadow");
            }
            filter();
          });
        });

        search.addEventListener("input", filter);
        distanceSelect.addEventListener("change", filter);
        filter();
      });
    </script>
  </body>
</html>
