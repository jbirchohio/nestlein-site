---
import { getCollection } from 'astro:content';
import "../styles/tailwind.css";

const locations = await getCollection('locations');
const groupedLocations = locations.map(loc => loc.data);
---

<html>
  <head>
    <title>NestleIn</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
  </head>
  <body class="bg-gradient-to-b from-orange-50 to-white font-sans">

    <header class="sticky top-0 bg-white shadow z-10 p-6 flex flex-col items-center gap-2">
      <div class="text-3xl font-extrabold text-orange-600 tracking-wide">NestleIn</div>
      <input id="search" placeholder="Search by name or tag..." class="border border-orange-300 px-4 py-2 w-full max-w-md rounded-full shadow-sm focus:ring-2 focus:ring-orange-400">
      <select id="distance-filter" class="mt-2 border border-orange-300 px-3 py-1 rounded-full text-sm">
        <option value="5">Within 5 mi</option>
        <option value="10" selected>Within 10 mi</option>
        <option value="25">Within 25 mi</option>
        <option value="50">Within 50 mi</option>
      </select>
    </header>

    <main class="px-4 py-6">
      <div id="dynamic-sections"></div>
    </main>

    <!-- ✅ Properly Injected JSON -->
    <script type="application/json" id="location-data">
      {Astro.raw(JSON.stringify(groupedLocations))}
    </script>

    <!-- ✅ Code waits for DOM to be ready -->
    <script>
      document.addEventListener("DOMContentLoaded", () => {
        try {
          const dataText = document.getElementById("location-data").textContent;
          const locations = JSON.parse(dataText);
          console.log("✅ Loaded JSON:", locations);

          const container = document.getElementById("dynamic-sections");
          locations.slice(0, 3).forEach(loc => {
            const el = document.createElement("div");
            el.className = "bg-white p-4 rounded shadow mb-4 border";
            el.innerHTML = `
              <h2 class="text-lg font-bold text-orange-600">${loc.name}</h2>
              <p class="text-sm text-gray-600">${loc.address}</p>
            `;
            container.appendChild(el);
          });

        } catch (err) {
          console.error("🔥 JSON Failed:", err);
          document.body.innerHTML += `<pre style="color:red;">🔥 ${err.message}</pre>`;
        }
      });
    </script>
 
  </body>
</html>
