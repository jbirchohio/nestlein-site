---
import "../styles/tailwind.css";
import { getCollection } from 'astro:content';

const locations = await getCollection('locations');

function haversineDistance(lat1, lon1, lat2, lon2) {
  const toRad = angle => (angle * Math.PI) / 180;
  const R = 6371;
  const dLat = toRad(lat2 - lat1);
  const dLon = toRad(lon2 - lon1);
  const a = Math.sin(dLat / 2) ** 2 +
            Math.cos(toRad(lat1)) * Math.cos(toRad(lat2)) *
            Math.sin(dLon / 2) ** 2;
  const c = 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1 - a));
  return R * c;
}

const userLat = Number(Astro.url.searchParams.get('lat')) || null;
const userLon = Number(Astro.url.searchParams.get('lon')) || null;

const locationsWithDistance = userLat && userLon
  ? locations.map(loc => {
      const { latitude, longitude } = loc.data;
      const distance = (latitude && longitude)
        ? haversineDistance(userLat, userLon, latitude, longitude)
        : Infinity;
      return { ...loc, distance };
    }).sort((a, b) => a.distance - b.distance)
  : locations.sort((a, b) => b.data.restaurant_score - a.data.restaurant_score);

const pageSize = 9;
const totalPages = Math.ceil(locationsWithDistance.length / pageSize);
const currentPage = Number(Astro.url.searchParams.get('page') || '1');
const paginatedLocations = locationsWithDistance.slice((currentPage - 1) * pageSize, currentPage * pageSize);
---

<html>
  <head>
    <title>NestleIn - Remote-Friendly Spots</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://maps.googleapis.com/maps/api/js?key=AIzaSyCEO1TGDpIshj-gXZH_V-0uWRpVLxHeOlM&callback=initMap" async defer></script>
  </head>
  <body class="bg-gradient-to-br from-white to-gray-100 text-gray-800 font-sans">
    <header class="sticky top-0 bg-white shadow z-10 p-4 flex flex-col sm:flex-row justify-between items-center gap-4">
      <div class="flex items-center gap-3">
        <img src="/logo.svg" alt="NestleIn Logo" class="w-10 h-10">
        <h1 class="text-3xl font-extrabold text-teal-700">NestleIn</h1>
      </div>
      <p class="text-sm text-gray-600">Find your perfect remote work vibe рџЊї</p>
    </header>

    <main class="p-4 max-w-7xl mx-auto">
      <section class="mb-8">
        <input id="search" type="text" placeholder="Search by name or tag..." class="w-full border border-gray-300 rounded-lg px-4 py-3 shadow-sm focus:outline-none focus:ring-2 focus:ring-teal-500" oninput="filterCards()">
      </section>

      <section class="mb-8">
        <div class="flex flex-wrap gap-2">
          <button class="px-3 py-1 rounded-full bg-teal-100 text-teal-700 hover:bg-teal-200 transition" onclick="filterByTag('Wi-Fi')">рџ“¶ Wi-Fi</button>
          <button class="px-3 py-1 rounded-full bg-yellow-100 text-yellow-800 hover:bg-yellow-200 transition" onclick="filterByTag('Vegan')">рџҐ— Vegan</button>
          <button class="px-3 py-1 rounded-full bg-pink-100 text-pink-700 hover:bg-pink-200 transition" onclick="filterByTag('Family-Friendly')">рџ‘ЁвЂЌрџ‘©вЂЌрџ‘§вЂЌрџ‘¦ Family</button>
          <button class="px-3 py-1 rounded-full bg-blue-100 text-blue-700 hover:bg-blue-200 transition" onclick="filterByTag('Open')">рџ•’ Open Now</button>
        </div>
      </section>

      <section id="card-container" class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-6">
        {paginatedLocations.map(({ data, distance }) => {
          const isOpen = data.hours_of_operation && data.hours_of_operation.includes(new Date().toLocaleString('en-US', { weekday: 'long' }));
          const hasWifi = data.remote_work_features?.wi_fi_quality && data.remote_work_features.wi_fi_quality.toLowerCase().includes('fast');
          return (
            <a href={`/locations/${data.slug}`} class="block bg-white rounded-xl shadow-md hover:shadow-lg transition overflow-hidden border border-gray-100" data-tags={`Tags: ${data.tags.join(', ')} ${isOpen ? 'Open' : ''} ${hasWifi ? 'Wi-Fi' : ''}`}> 
              {data.logo_url && <img src={data.logo_url} alt={data.name + ' logo'} class="w-full h-48 object-cover">}
              <div class="p-4">
                <h3 class="text-xl font-semibold text-gray-900">{data.name}</h3>
                <p class="text-sm text-gray-600">{data.address}</p>
                <p class="mt-1 text-sm text-gray-700 font-medium">в­ђ {data.restaurant_score}/10</p>
                <p class="text-sm text-gray-700">рџ§  Best Time: {data.best_time_to_work_remotely}</p>
                {distance !== undefined && isFinite(distance) && <p class="text-sm text-gray-500">рџ“Ќ {distance.toFixed(1)} km away</p>}
                <div class="mt-2 flex flex-wrap gap-1">
                  {data.tags.map(tag => <span class="text-xs bg-teal-50 border border-teal-200 text-teal-700 px-2 py-1 rounded-full">{tag}</span>)}
                </div>
              </div>
            </a>
          );
        })}
      </section>

      <div class="mt-10 flex justify-center gap-2">
        {Array.from({ length: totalPages }).map((_, i) => (
          <a href={`/?page=${i + 1}`} class={`px-4 py-2 rounded-lg ${currentPage === i + 1 ? 'bg-teal-600 text-white' : 'bg-gray-200 text-gray-800'}`}>{i + 1}</a>
        ))}
      </div>

      <section class="mt-16">
        <h2 class="text-lg font-semibold mb-2">Map View</h2>
        <div id="map" class="w-full h-96 rounded-lg shadow border border-gray-200"></div>
      </section>
    </main>

    <footer class="mt-16 p-6 text-center text-sm text-gray-500 border-t">
      Built with рџ’» by Jonas | <a href="/suggest" class="text-teal-600 hover:underline">Suggest a Spot</a>
    </footer>

    <script>
      function filterCards() {
        const search = document.getElementById('search').value.toLowerCase();
        const cards = document.querySelectorAll('#card-container a');
        cards.forEach(card => {
          const tags = card.getAttribute('data-tags')?.toLowerCase() || '';
          const text = card.textContent.toLowerCase();
          card.style.display = text.includes(search) || tags.includes(search) ? 'block' : 'none';
        });
      }

      function filterByTag(tag) {
        const cards = document.querySelectorAll('#card-container a');
        cards.forEach(card => {
          const tags = card.getAttribute('data-tags') || '';
          card.style.display = tags.includes(tag) ? 'block' : 'none';
        });
      }

      function initMap() {
        const map = new google.maps.Map(document.getElementById("map"), {
          center: { lat: 41.08, lng: -81.51 },
          zoom: 12,
        });

        const locations = JSON.parse(document.querySelector('[type="application/json"]').textContent);
        locations.forEach(loc => {
          if (loc.data.latitude && loc.data.longitude) {
            new google.maps.Marker({
              position: { lat: loc.data.latitude, lng: loc.data.longitude },
              map: map,
              title: loc.data.name,
            });
          }
        });
      }

      if (navigator.geolocation) {
        navigator.geolocation.getCurrentPosition(function(position) {
          const { latitude, longitude } = position.coords;
          const url = new URL(window.location.href);
          url.searchParams.set('lat', latitude);
          url.searchParams.set('lon', longitude);
          window.history.replaceState({}, '', url.toString());
        });
      }
    </script>

    <script type="application/json" id="location-data">
      {JSON.stringify(paginatedLocations)}
    </script>
  </body>
</html>
