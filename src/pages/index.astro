---
import "../styles/tailwind.css";
import { getCollection } from 'astro:content';

const locations = await getCollection('locations');

function haversineDistance(lat1, lon1, lat2, lon2) {
  const toRad = angle => (angle * Math.PI) / 180;
  const R = 6371; // km
  const dLat = toRad(lat2 - lat1);
  const dLon = toRad(lon2 - lon1);
  const a = Math.sin(dLat / 2) ** 2 +
            Math.cos(toRad(lat1)) * Math.cos(toRad(lat2)) *
            Math.sin(dLon / 2) ** 2;
  const c = 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1 - a));
  return R * c;
}

const userLat = Number(Astro.url.searchParams.get('lat')) || null;
const userLon = Number(Astro.url.searchParams.get('lon')) || null;

const locationsWithDistance = userLat && userLon
  ? locations.map(loc => {
      const { latitude, longitude } = loc.data;
      const distance = (latitude && longitude)
        ? haversineDistance(userLat, userLon, latitude, longitude)
        : Infinity;
      return { ...loc, distance };
    }).sort((a, b) => a.distance - b.distance)
  : locations.sort((a, b) => b.data.restaurant_score - a.data.restaurant_score);

const pageSize = 9;
const totalPages = Math.ceil(locationsWithDistance.length / pageSize);
const currentPage = Number(Astro.url.searchParams.get('page') || '1');
const paginatedLocations = locationsWithDistance.slice((currentPage - 1) * pageSize, currentPage * pageSize);
---

<html>
  <head>
    <title>NestleIn - Remote-Friendly Spots</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
  </head>
  <body class="bg-white font-sans">
    <header class="sticky top-0 bg-white shadow z-10 p-4 flex flex-col sm:flex-row justify-between items-center gap-2">
      <h1 class="text-2xl font-bold text-gray-800">NestleIn</h1>
      <input id="search" type="text" placeholder="Search by name or tag..." class="border px-4 py-2 rounded w-full sm:w-1/3" oninput="filterCards()">
    </header>

    <main class="p-4">
      <section class="mb-6">
        <h2 class="text-lg font-semibold mb-2">Filters</h2>
        <div id="filters" class="flex flex-wrap gap-2">
          <button class="px-3 py-1 rounded-full bg-gray-200" onclick="filterByTag('Wi-Fi')">Wi-Fi</button>
          <button class="px-3 py-1 rounded-full bg-gray-200" onclick="filterByTag('Vegan')">Vegan</button>
          <button class="px-3 py-1 rounded-full bg-gray-200" onclick="filterByTag('Family-Friendly')">Family-Friendly</button>
          <button class="px-3 py-1 rounded-full bg-gray-200" onclick="filterByTag('Open')">Open Now</button>
        </div>
      </section>

      <section id="card-container" class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-6">
        {paginatedLocations.map(({ data, distance }) => {
          const isOpen = data.hours_of_operation && data.hours_of_operation.includes(new Date().toLocaleString('en-US', { weekday: 'long' }));
          const hasWifi = data.remote_work_features?.wi_fi_quality && data.remote_work_features.wi_fi_quality.toLowerCase().includes('fast');
          return (
            <a href={`/locations/${data.slug}`} class="block bg-white rounded shadow hover:bg-gray-50 transition overflow-hidden" data-tags={`Tags: ${data.tags.join(', ')} ${isOpen ? 'Open' : ''} ${hasWifi ? 'Wi-Fi' : ''}`}> 
              {data.logo_url && <img src={data.logo_url} alt={data.name + ' logo'} class="w-full h-48 object-cover">}
              <div class="p-4">
                <h3 class="text-xl font-semibold text-gray-900">{data.name}</h3>
                <p class="text-sm text-gray-600">{data.address}</p>
                <p class="mt-2 text-sm text-gray-700 font-medium">Score: {data.restaurant_score}/10</p>
                <p class="text-sm text-gray-700">🧠 Best Time: {data.best_time_to_work_remotely}</p>
                {distance !== undefined && isFinite(distance) && <p class="text-sm text-gray-500">📍 {distance.toFixed(1)} km away</p>}
                <div class="mt-2 flex flex-wrap gap-1">
                  {data.tags.map(tag => <span class="text-xs bg-green-200 px-2 py-1 rounded-full">{tag}</span>)}
                </div>
              </div>
            </a>
          );
        })}
      </section>

      <div class="mt-8 flex justify-center gap-2">
        {Array.from({ length: totalPages }).map((_, i) => (
          <a href={`/?page=${i + 1}`} class={`px-3 py-1 rounded ${currentPage === i + 1 ? 'bg-blue-600 text-white' : 'bg-gray-200 text-gray-800'}`}>{i + 1}</a>
        ))}
      </div>

      <section class="mt-12">
        <h2 class="text-lg font-semibold mb-2">Map View</h2>
        <div id="map" class="w-full h-96 rounded shadow"></div>
      </section>
    </main>

    <script>
      function filterCards() {
        const search = document.getElementById('search').value.toLowerCase();
        const cards = document.querySelectorAll('#card-container a');
        cards.forEach(card => {
          const tags = card.getAttribute('data-tags')?.toLowerCase() || '';
          const text = card.textContent.toLowerCase();
          card.style.display = text.includes(search) || tags.includes(search) ? 'block' : 'none';
        });
      }

      function filterByTag(tag) {
        const cards = document.querySelectorAll('#card-container a');
        cards.forEach(card => {
          const tags = card.getAttribute('data-tags') || '';
          card.style.display = tags.includes(tag) ? 'block' : 'none';
        });
      }

      if (navigator.geolocation) {
        navigator.geolocation.getCurrentPosition(function(position) {
          const { latitude, longitude } = position.coords;
          const url = new URL(window.location.href);
          url.searchParams.set('lat', latitude);
          url.searchParams.set('lon', longitude);
          window.history.replaceState({}, '', url.toString());
        });
      }

      const map = L.map('map').setView([41.08, -81.51], 12); // Adjust the default view if needed

      L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
        maxZoom: 19,
        attribution: '© OpenStreetMap'
      }).addTo(map);

      const locations = JSON.parse(document.querySelector('[type="application/json"]').textContent);
      locations.forEach(loc => {
        if (loc.data.latitude && loc.data.longitude) {
          L.marker([loc.data.latitude, loc.data.longitude])
            .addTo(map)
            .bindPopup(`<strong>${loc.data.name}</strong><br>${loc.data.address}`);
        }
      });
    </script>
    <script type="application/json" id="location-data">
      {JSON.stringify(paginatedLocations)}
    </script>
  </body>
</html>
