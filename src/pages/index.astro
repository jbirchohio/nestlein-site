---
import "../styles/tailwind.css";
import { getCollection } from 'astro:content';

const locations = await getCollection('locations');

const groupedLocations = locations.map(loc => ({
  ...loc.data,
  slug: loc.slug
}));

const safeJson = JSON.stringify(groupedLocations).replace(/</g, '\\u003c');
---

<html>
  <head>
    <title>NestleIn</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
  </head>
  <body class="bg-gradient-to-b from-orange-50 to-white font-sans">

    <header class="sticky top-0 bg-white shadow z-10 p-6 flex flex-col items-center gap-2">
      <div class="text-3xl font-extrabold text-orange-600 tracking-wide">NestleIn</div>
      <input id="search" placeholder="Search by name or tag..." class="border border-orange-300 px-4 py-2 w-full max-w-md rounded-full shadow-sm focus:ring-2 focus:ring-orange-400">
      <select id="distance-filter" class="mt-2 border border-orange-300 px-3 py-1 rounded-full text-sm">
        <option value="5">Within 5 mi</option>
        <option value="10" selected>Within 10 mi</option>
        <option value="25">Within 25 mi</option>
        <option value="50">Within 50 mi</option>
      </select>
    </header>

    <main class="px-4 py-6 space-y-12">
      <div id="dynamic-sections"></div>
    </main>

    <!-- ✅ Inject location data -->
    <script type="application/json" id="location-data" set:html={safeJson}></script>

    <!-- ✅ Client-side JS to render 3 random tag sections with 3 random cards each -->
    <script>
      document.addEventListener("DOMContentLoaded", () => {
        const locations = JSON.parse(document.getElementById("location-data").textContent);
        const container = document.getElementById("dynamic-sections");
        const search = document.getElementById("search");
        const distanceSelect = document.getElementById("distance-filter");

        // 🎲 Step 1: Get unique tags and shuffle them
        const allTags = Array.from(new Set(locations.flatMap(loc => loc.tags || [])));
        const shuffledTags = allTags.sort(() => 0.5 - Math.random()).slice(0, 3);

        // 🧩 Step 2: Build and render sections
        container.innerHTML = '';
        shuffledTags.forEach(tag => {
          const matches = locations.filter(loc => loc.tags?.includes(tag));
          const randomCards = matches.sort(() => 0.5 - Math.random()).slice(0, 3);

          if (randomCards.length === 0) return;

          const section = document.createElement('section');
          const title = document.createElement('h2');
          title.className = "text-xl font-semibold text-orange-600 mb-4 px-2";
          title.textContent = tag;

          const grid = document.createElement('div');
          grid.className = "grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4";

          randomCards.forEach(loc => {
            const card = document.createElement("a");
            card.href = `/locations/${loc.slug}`;
            card.className = "block bg-white rounded-lg border border-orange-200 shadow hover:shadow-md transition overflow-hidden location-card text-sm w-full max-w-[250px] mx-auto";
            card.dataset.tags = (loc.tags || []).join(", ").toLowerCase();
            card.dataset.lat = loc.latitude;
            card.dataset.lon = loc.longitude;

            const content = document.createElement("div");
            content.className = "p-3";
            content.innerHTML = `
              <h3 class="text-base font-semibold text-orange-700 mb-1">${loc.name}</h3>
              <p class="text-xs text-gray-600">${loc.address || ""}</p>
              <p class="text-xs text-gray-700 mt-1 font-medium">⭐ ${loc.restaurant_score || 0}/10</p>
              <p class="text-xs text-gray-700">🧠 ${loc.best_time_to_work_remotely || ""}</p>
              <div class="mt-2 flex flex-wrap gap-1">
                ${(loc.tags || []).map(tag => `
                  <span class="text-[10px] bg-orange-100 text-orange-700 px-2 py-0.5 rounded-full">${tag}</span>
                `).join("")}
              </div>
            `;

            card.appendChild(content);
            grid.appendChild(card);
          });

          section.appendChild(title);
          section.appendChild(grid);
          container.appendChild(section);
        });

        // 🔍 Distance and search filter
        function haversine(lat1, lon1, lat2, lon2) {
          const toRad = angle => angle * Math.PI / 180;
          const R = 6371;
          const dLat = toRad(lat2 - lat1);
          const dLon = toRad(lat2 - lon1);
          const a = Math.sin(dLat / 2) ** 2 + Math.cos(toRad(lat1)) * Math.cos(toRad(lat2)) * Math.sin(dLon / 2) ** 2;
          const c = 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1 - a));
          return R * c * 0.621371;
        }

        function filter() {
          const q = search.value.toLowerCase();
          const maxDistance = parseInt(distanceSelect.value);
          const url = new URL(window.location.href);
          const lat = parseFloat(url.searchParams.get("lat"));
          const lon = parseFloat(url.searchParams.get("lon"));

          document.querySelectorAll(".location-card").forEach(card => {
            const name = card.querySelector("h3")?.textContent?.toLowerCase() || "";
            const tags = card.dataset.tags || "";
            const cardLat = parseFloat(card.dataset.lat);
            const cardLon = parseFloat(card.dataset.lon);

            const matchText = name.includes(q) || tags.includes(q);
            const matchDistance = (lat && lon && cardLat && cardLon)
              ? haversine(lat, lon, cardLat, cardLon) <= maxDistance
              : true;

            card.style.display = matchText && matchDistance ? "block" : "none";
          });
        }

        search.addEventListener("input", filter);
        distanceSelect.addEventListener("change", filter);
        filter();

        // 🌍 Auto-locate
        if (navigator.geolocation && !window.location.search.includes("lat")) {
          navigator.geolocation.getCurrentPosition(pos => {
            const url = new URL(window.location.href);
            url.searchParams.set("lat", pos.coords.latitude);
            url.searchParams.set("lon", pos.coords.longitude);
            window.location.href = url.toString();
          });
        }
      });
    </script>
  </body>
</html>
