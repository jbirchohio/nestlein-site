---
import Layout from '../../layouts/Layout.astro';
import fs from 'fs';
import path from 'path';

export async function getStaticPaths() {
  const directoryPath = path.resolve('./data/locations');
  const files = fs.readdirSync(directoryPath);
  return files.map(file => ({
    params: { slug: file.replace('.json', '') }
  }));
}

const { slug } = Astro.params;
const filePath = path.resolve('./data/locations', `${slug}.json`);
let location = null;

try {
  const raw = fs.readFileSync(filePath, 'utf8');
  location = JSON.parse(raw);
} catch (err) {
  console.error('Error loading location JSON:', err);
}

const data = location;
---

<Layout title={data.name}>
  <!-- Your page HTML goes here -->

<html lang="en">
  <head>
    <title>{data.name} - NestleIn</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link href="/src/styles/tailwind.css" rel="stylesheet" />
  </head>
  <body class="bg-gradient-to-br from-orange-50 to-white min-h-screen font-sans text-gray-800">
    <main class="max-w-5xl mx-auto px-6 py-12 space-y-12">

      <a href="/" class="text-sm text-purple-600 hover:underline">← Back to homepage</a>

      <div class="rounded-xl overflow-hidden shadow-lg border border-orange-200">
        {data.logo_url && (
          <img src={data.logo_url} alt={`${data.name} logo`} class="w-full h-60 sm:h-72 object-cover" />
        )}
      </div>

      <h1 class="text-4xl sm:text-5xl font-extrabold text-orange-600 border-b border-orange-200 pb-2">{data.name}</h1>

      <section class="grid gap-4 bg-white p-6 rounded-xl shadow-md border border-orange-100 text-base">
        <p><span class="font-semibold text-pink-600">📍 Address:</span> {data.address}</p>
        <p><span class="font-semibold text-red-500">📞 Phone:</span> {data.phone_number}</p>
        <p><span class="font-semibold text-orange-500">⏰ Hours:</span> {data.hours_of_operation}</p>
        <p><span class="font-semibold text-yellow-500">⭐ Score:</span> {data.restaurant_score}/10</p>
        <p><span class="font-semibold text-purple-500">🧠 Best Time:</span> {data.best_time_to_work_remotely}</p>
      </section>

      <section class="bg-white rounded-xl shadow-md border border-orange-100 p-6">
        <h2 class="text-2xl font-semibold text-orange-600 mb-4 flex items-center gap-2">💻 Remote Work Features</h2>
        <ul class="grid sm:grid-cols-2 gap-x-6 gap-y-3 text-sm list-disc list-inside">
          <li><strong>Wi-Fi:</strong> {data.remote_work_features?.wi_fi_quality || "Unknown"}</li>
          <li><strong>Outlets:</strong> {data.remote_work_features?.outlet_access || "Unknown"}</li>
          <li><strong>Noise Level:</strong> {data.remote_work_features?.noise_level || "Unknown"}</li>
          <li><strong>Seating:</strong> {data.remote_work_features?.seating_comfort || "Unknown"}</li>
          <li><strong>Natural Light:</strong> {data.remote_work_features?.natural_light || "Unknown"}</li>
          <li><strong>Stay Duration:</strong> {data.remote_work_features?.stay_duration_friendliness || "Not specified"}</li>
          <li><strong>Food/Drink:</strong> {data.remote_work_features?.food_drink_options || "Unknown"}</li>
          <li><strong>Bathrooms:</strong> {data.remote_work_features?.bathroom_access || "Unknown"}</li>
          <li><strong>Parking:</strong> {data.remote_work_features?.parking_availability || "Unknown"}</li>
        </ul>
      </section>

      {data.tags?.length > 0 && (
        <section>
          <h2 class="text-xl font-bold text-orange-600 mb-2">🏷️ Tags</h2>
          <div class="flex flex-wrap gap-2">
            {data.tags.map(tag => (
              <span class="bg-orange-100 text-orange-700 px-3 py-1 rounded-full text-xs font-semibold shadow-sm">
                {tag}
              </span>
            ))}
          </div>
        </section>
      )}

      <footer class="mt-10 pt-6 border-t text-center text-sm text-gray-500">
        <p>
          ✨ Powered by <span class="text-orange-600 font-semibold">NestleIn</span> ·
          <a href="/" class="text-purple-500 hover:underline ml-1">Return Home</a>
        </p>
      </footer>
    </main>
  </body>
</html>
  <h1 class="text-4xl font-bold text-orange-600">{data.name}</h1>
</Layout>
