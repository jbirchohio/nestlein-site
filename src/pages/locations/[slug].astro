---
import fs from 'fs';
import path from 'path';
import "../../styles/tailwind.css";

export async function getStaticPaths() {
  const directory = path.resolve('./data/locations');
  const files = fs.readdirSync(directory);
  const paths = [];

  for (const file of files) {
    const raw = fs.readFileSync(path.join(directory, file), 'utf-8');
    const data = JSON.parse(raw);
    if (data.slug) {
      paths.push({ params: { slug: data.slug } });
    }
  }

  return paths;
}

const { slug } = Astro.params;
const directoryPath = path.resolve('./data/locations');
const files = fs.readdirSync(directoryPath);

let location = null;
let allLocations = [];

for (const file of files) {
  const raw = fs.readFileSync(path.join(directoryPath, file), 'utf8');
  const json = JSON.parse(raw);
  allLocations.push(json);
  if (json.slug === slug) {
    location = json;
  }
}

if (!location) {
  throw new Error(`Location with slug "${slug}" not found.`);
}

// Haversine function
function haversine(lat1, lon1, lat2, lon2) {
  const toRad = angle => angle * Math.PI / 180;
  const R = 6371; // km
  const dLat = toRad(lat2 - lat1);
  const dLon = toRad(lon2 - lon1);
  const a =
    Math.sin(dLat / 2) ** 2 +
    Math.cos(toRad(lat1)) * Math.cos(toRad(lat2)) * Math.sin(dLon / 2) ** 2;
  const c = 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1 - a));
  return R * c * 0.621371; // Convert to miles
}

// Nearby spots: within 10mi, limit 3
const nearbySpots =
  location.latitude && location.longitude
    ? allLocations
        .filter(
          l =>
            l.slug !== slug &&
            l.latitude &&
            l.longitude
        )
        .map(l => ({
          ...l,
          distance: haversine(location.latitude, location.longitude, l.latitude, l.longitude),
        }))
        .filter(l => l.distance <= 10)
        .sort((a, b) => a.distance - b.distance)
        .slice(0, 3)
    : [];
---

<html>
  <head>
    <title>{location.name} – NestleIn</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  </head>
  <body class="bg-orange-50 font-sans text-gray-800">
    <main class="max-w-3xl mx-auto px-4 py-10 space-y-8">

      <a href="/" class="inline-block text-sm text-orange-600 underline hover:text-orange-800 transition">← Back to Discover</a>

      {location.image_url && <img src={location.image_url} alt={location.name} class="w-full h-64 object-cover rounded-xl shadow-md" />}

      <div>
        <h1 class="text-4xl font-bold text-orange-700">{location.name}</h1>
        <p class="text-gray-600 text-sm mt-1">{location.address}</p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div class="bg-white rounded-lg shadow p-4 space-y-2">
          <p><span class="inline-block text-yellow-500">⭐</span> <strong>Remote Score:</strong> {location.restaurant_score}/10</p>
          <p><span class="inline-block text-pink-500">🧠</span> <strong>Best Time:</strong> {location.best_time_to_work_remotely}</p>
          <p><span class="inline-block text-gray-600">🕒</span> <strong>Hours:</strong> {location.hours_of_operation}</p>
        </div>

        <div class="bg-white rounded-lg shadow p-4">
          <strong class="block text-sm mb-1 text-orange-700">Tags</strong>
          <div class="flex flex-wrap gap-2">
            {location.tags?.map(tag => (
              <span class="text-xs bg-orange-100 text-orange-700 px-2 py-0.5 rounded-full">{tag}</span>
            ))}
          </div>
        </div>
      </div>

      {location.remote_work_features && (
        <div class="bg-white rounded-lg shadow p-6">
          <h2 class="text-lg font-semibold text-orange-700 mb-4">Remote Work Features</h2>
          <ul class="list-disc list-inside text-sm text-gray-700 space-y-1">
            {Object.entries(location.remote_work_features).map(([key, value]) => (
              <li><strong>{key.replace(/_/g, ' ')}:</strong> {value}</li>
            ))}
          </ul>
        </div>
      )}

      <div class="flex flex-wrap gap-4 mt-6">
        {location.website_url && (
          <a href={location.website_url} class="bg-orange-100 text-orange-700 px-4 py-2 text-sm rounded-full hover:bg-orange-200 transition" target="_blank" rel="noopener">Visit Website</a>
        )}
        {location.latitude && location.longitude && (
          <a href={`https://www.google.com/maps/search/?api=1&query=${location.latitude},${location.longitude}`} class="bg-orange-100 text-orange-700 px-4 py-2 text-sm rounded-full hover:bg-orange-200 transition" target="_blank" rel="noopener">View on Map</a>
        )}
      </div>

      {nearbySpots.length > 0 && (
        <div class="mt-10">
          <h2 class="text-xl font-semibold text-orange-700 mb-4">Nearby Spots</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            {nearbySpots.map(spot => (
              <a href={`/locations/${spot.slug}`} class="block bg-white rounded-lg border border-orange-100 shadow p-4 hover:shadow-md transition">
                <h3 class="text-lg font-semibold text-orange-800 mb-1">{spot.name}</h3>
                <p class="text-sm text-gray-500">{spot.address}</p>
                <p class="text-xs text-gray-600 mt-1">📍 {spot.distance.toFixed(1)} mi away</p>
                <p class="text-sm">⭐ {spot.restaurant_score || 0}/10</p>
                <div class="mt-2 flex flex-wrap gap-1">
                  {(spot.tags || []).map(tag => (
                    <span class="text-xs bg-orange-100 text-orange-700 px-2 py-0.5 rounded-full">{tag}</span>
                  ))}
                </div>
              </a>
            ))}
          </div>
        </div>
      )}
    </main>
  </body>
</html>
