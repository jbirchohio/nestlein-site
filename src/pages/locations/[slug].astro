---
import fs from 'fs';
import path from 'path';

const { slug } = Astro.params;

const directoryPath = path.resolve('./data/locations');
const files = fs.readdirSync(directoryPath);

let location = null;

for (const file of files) {
  const raw = fs.readFileSync(path.join(directoryPath, file), 'utf8');
  const json = JSON.parse(raw);
  if (json.slug === slug) {
    location = json;
    break;
  }
}

if (!location) {
  throw new Error(`Location with slug "${slug}" not found.`);
}
---

<html>
  <head>
    <title>{location.name} – NestleIn</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  </head>
  <body class="bg-gradient-to-b from-orange-50 to-white font-sans">
    <main class="max-w-2xl mx-auto px-4 py-8">
      <h1 class="text-3xl font-extrabold text-orange-600 mb-2">{location.name}</h1>
      <p class="text-sm text-gray-600 mb-4">{location.address}</p>
      <p class="text-sm mb-1"><strong>⭐ Rating:</strong> {location.restaurant_score}/10</p>
      <p class="text-sm mb-1"><strong>Best time to work remotely:</strong> {location.best_time_to_work_remotely}</p>
      <p class="text-sm mb-4"><strong>Hours:</strong> {location.hours_of_operation}</p>

      <div class="mb-4">
        <strong class="text-sm block mb-1">Tags:</strong>
        <div class="flex flex-wrap gap-2">
          {location.tags?.map(tag => (
            <span class="text-xs bg-orange-100 text-orange-700 px-2 py-0.5 rounded-full">{tag}</span>
          ))}
        </div>
      </div>

      <div class="mt-6">
        <strong class="block text-sm mb-1">Remote Work Features:</strong>
        <ul class="list-disc list-inside text-sm text-gray-700">
          {Object.entries(location.remote_work_features || {}).map(([key, value]) => (
            <li><strong>{key.replace(/_/g, ' ')}:</strong> {value}</li>
          ))}
        </ul>
      </div>

      <div class="mt-8 text-sm text-gray-500">
        {location.website_url && <a href={location.website_url} class="underline text-orange-600" target="_blank">Visit Website</a>}
      </div>
    </main>
  </body>
</html>
