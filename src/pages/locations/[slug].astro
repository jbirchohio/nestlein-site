---
import fs from 'fs';
import path from 'path';
import { Astro } from 'astro';

const { slug } = Astro.params;

const filePath = path.resolve(Astro.root, 'src/data/locations', `${slug}.json`);
let location = null;

try {
  const raw = fs.readFileSync(filePath, 'utf8');
  location = JSON.parse(raw);
} catch (err) {
  console.error('Error loading location JSON:', err);
}
---

<html>
  <head>
    <title>{location?.name || 'NestleIn Listing'}</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
  </head>
  <body class="p-6 font-sans bg-gray-50 text-gray-900">
    <a href="/" class="block text-blue-600 underline mb-4">← Back to homepage</a>

    {location ? (
      <div class="max-w-2xl mx-auto bg-white p-6 rounded shadow">
        <h1 class="text-3xl font-bold mb-2">{location.name}</h1>
        <p class="text-sm text-gray-600 mb-1">{location.address}</p>
        <p class="text-sm text-gray-600 mb-4">{location.phone_number}</p>
        {location.logo_url && (
          <img src={location.logo_url} alt={location.name + ' logo'} class="w-full h-64 object-cover rounded mb-4" />
        )}
        <div class="mb-4">
          <p><strong>Hours:</strong> {location.hours_of_operation}</p>
          <p><strong>Score:</strong> {location.restaurant_score}/10</p>
          <p><strong>Best Time to Work Remotely:</strong> {location.best_time_to_work_remotely}</p>
        </div>

        <div class="mb-4">
          <h2 class="font-semibold text-lg mb-2">Remote Work Features</h2>
          <ul class="list-disc pl-6 space-y-1">
            {Object.entries(location.remote_work_features || {}).map(([key, value]) => (
              <li><strong>{key.replace(/_/g, ' ')}:</strong> {value}</li>
            ))}
          </ul>
        </div>

        <div>
          <h2 class="font-semibold text-lg mb-2">Tags</h2>
          <div class="flex flex-wrap gap-2">
            {location.tags?.map(tag => (
              <span class="px-3 py-1 bg-blue-100 text-blue-800 text-xs rounded-full">{tag}</span>
            ))}
          </div>
        </div>
      </div>
    ) : (
      <div class="text-center text-red-600 text-xl">Location not found.</div>
    )}
  </body>
</html>
