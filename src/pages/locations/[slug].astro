---
import fs from 'fs';
import path from 'path';

export async function getStaticPaths() {
  const directoryPath = path.resolve('./data/locations');
  const files = fs.readdirSync(directoryPath);

  const paths = files
    .filter(file => file.endsWith('.json'))
    .map(file => ({
      params: { slug: file.replace('.json', '') }
    }));

  return paths;
}

const { slug } = Astro.params;
const filePath = path.resolve('./data/locations', `${slug}.json`);
let location = null;

try {
  const raw = fs.readFileSync(filePath, 'utf8');
  location = JSON.parse(raw);
} catch (err) {
  console.error('Error loading location JSON:', err);
}

const data = location;
---

<html lang="en"> 
  <head>
    <title>{data.name} - NestleIn</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link href="/styles/tailwind.css" rel="stylesheet" />
  </head>
  <body class="bg-orange-50 text-gray-900 font-sans">
    <main class="max-w-3xl mx-auto p-6 space-y-8">
      <a href="/" class="text-purple-600 hover:underline text-sm inline-block">← Back to homepage</a>

      {data.logo_url && (
        <img src={data.logo_url} alt={`${data.name} logo`} class="w-full h-64 object-cover rounded-lg shadow-md border border-orange-300" />
      )}

      <h1 class="text-4xl font-extrabold text-orange-600 mt-4">{data.name}</h1>

      <div class="bg-white border shadow-md rounded-lg p-6 space-y-3 text-sm leading-relaxed">
        <p><span class="font-bold text-pink-600">📍 Address:</span> {data.address}</p>
        <p><span class="font-bold text-red-500">📞 Phone:</span> {data.phone_number}</p>
        <p><span class="font-bold text-orange-500">⏰ Hours:</span> {data.hours_of_operation}</p>
        <p><span class="font-bold text-yellow-600">⭐ Score:</span> {data.restaurant_score}/10</p>
        <p><span class="font-bold text-purple-600">🧠 Best Time to Work Remotely:</span> {data.best_time_to_work_remotely}</p>
      </div>

      <section class="bg-white border rounded-lg p-6 shadow space-y-4">
        <h2 class="text-2xl font-bold text-orange-600 flex items-center gap-2">💻 Remote Work Features</h2>
        <ul class="grid sm:grid-cols-2 gap-3 text-sm list-disc list-inside">
          <li><strong>Wi-Fi:</strong> {data.remote_work_features?.wi_fi_quality || "Unknown"}</li>
          <li><strong>Outlets:</strong> {data.remote_work_features?.outlet_access || "Unknown"}</li>
          <li><strong>Noise Level:</strong> {data.remote_work_features?.noise_level || "Unknown"}</li>
          <li><strong>Seating Comfort:</strong> {data.remote_work_features?.seating_comfort || "Unknown"}</li>
          <li><strong>Natural Light:</strong> {data.remote_work_features?.natural_light || "Unknown"}</li>
          <li><strong>Stay Duration:</strong> {data.remote_work_features?.stay_duration_friendliness || "Not specified"}</li>
          <li><strong>Food/Drink:</strong> {data.remote_work_features?.food_drink_options || "Unknown"}</li>
          <li><strong>Bathrooms:</strong> {data.remote_work_features?.bathroom_access || "Unknown"}</li>
          <li><strong>Parking:</strong> {data.remote_work_features?.parking_availability || "Unknown"}</li>
        </ul>
      </section>

      {data.tags?.length > 0 && (
        <section>
          <h2 class="text-lg font-bold text-orange-600 mb-2">🏷️ Tags</h2>
          <div class="flex flex-wrap gap-2">
            {data.tags.map(tag => (
              <span class="bg-orange-100 text-orange-700 px-3 py-1 rounded-full text-xs font-semibold shadow-sm">
                {tag}
              </span>
            ))}
          </div>
        </section>
      )}

      <footer class="mt-10 pt-6 border-t text-center text-sm text-gray-500">
        <p>✨ Powered by <span class="text-orange-600 font-semibold">NestleIn</span> · <a href="/" class="text-purple-500 hover:underline">Return Home</a></p>
      </footer>
    </main>
  </body>
</html>
