---
import fs from 'fs';
import path from 'path';

export async function getStaticPaths() {
  const directory = path.resolve('./data/locations');
  const files = fs.readdirSync(directory);
  const paths = [];

  for (const file of files) {
    const raw = fs.readFileSync(path.join(directory, file), 'utf-8');
    const data = JSON.parse(raw);
    if (data.slug) {
      paths.push({ params: { slug: data.slug } });
    }
  }

  return paths;
}

const { slug } = Astro.params;

const directoryPath = path.resolve('./data/locations');
const files = fs.readdirSync(directoryPath);

let location = null;

for (const file of files) {
  const raw = fs.readFileSync(path.join(directoryPath, file), 'utf8');
  const json = JSON.parse(raw);
  if (json.slug === slug) {
    location = json;
    break;
  }
}

if (!location) {
  throw new Error(`Location with slug "${slug}" not found.`);
}
---

<html>
  <head>
    <title>{location.name} – NestleIn</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  </head>
  <body class="bg-orange-50 font-sans">
    <main class="max-w-3xl mx-auto px-4 py-10 space-y-8">
      
      <!-- Image Header -->
      {location.image_url && (
        <img src={location.image_url} alt={location.name} class="w-full h-64 object-cover rounded-xl shadow-md" />
      )}

      <!-- Name & Address -->
      <div>
        <h1 class="text-4xl font-bold text-orange-700">{location.name}</h1>
        <p class="text-gray-600 text-sm mt-1">{location.address}</p>
      </div>

      <!-- Key Info -->
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div class="bg-white rounded-lg shadow p-4">
          <p class="text-sm text-gray-700"><strong>⭐ Remote Score:</strong> {location.restaurant_score}/10</p>
          <p class="text-sm text-gray-700"><strong>🧠 Best Time:</strong> {location.best_time_to_work_remotely}</p>
          <p class="text-sm text-gray-700"><strong>🕒 Hours:</strong> {location.hours_of_operation}</p>
        </div>

        <div class="bg-white rounded-lg shadow p-4">
          <strong class="block text-sm mb-1 text-orange-700">Tags</strong>
          <div class="flex flex-wrap gap-2">
            {location.tags?.map(tag => (
              <span class="text-xs bg-orange-100 text-orange-700 px-2 py-0.5 rounded-full">{tag}</span>
            ))}
          </div>
        </div>
      </div>

      <!-- Feature Breakdown -->
      {location.remote_work_features && (
        <div class="bg-white rounded-lg shadow p-6">
          <h2 class="text-lg font-semibold text-orange-700 mb-4">Remote Work Features</h2>
          <ul class="list-disc list-inside text-sm text-gray-700">
            {Object.entries(location.remote_work_features).map(([key, value]) => (
              <li><strong>{key.replace(/_/g, ' ')}:</strong> {value}</li>
            ))}
          </ul>
        </div>
      )}

      <!-- External Links -->
      <div class="text-sm text-orange-700 space-x-4 mt-4">
        {location.website_url && (
          <a href={location.website_url} class="underline" target="_blank" rel="noopener">Visit Website</a>
        )}
        {location.latitude && location.longitude && (
          <a
            href={`https://www.google.com/maps/search/?api=1&query=${location.latitude},${location.longitude}`}
            class="underline"
            target="_blank"
            rel="noopener"
          >View on Map</a>
        )}
      </div>
    </main>
  </body>
</html>
