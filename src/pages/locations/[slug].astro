---
import fs from 'fs';
import path from 'path';

export async function getStaticPaths() {
  const directoryPath = path.resolve('./data/locations');
  const files = fs.readdirSync(directoryPath);

  const paths = files
    .filter(file => file.endsWith('.json'))
    .map(file => ({
      params: { slug: file.replace('.json', '') }
    }));

  return paths;
}

const { slug } = Astro.params;
const filePath = path.resolve('./data/locations', `${slug}.json`);
let location = null;

try {
  const raw = fs.readFileSync(filePath, 'utf8');
  location = JSON.parse(raw);
} catch (err) {
  console.error('Error loading location JSON:', err);
}

const data = location;
---

<html lang="en">
  <head>
    <title>{data.name} - NestleIn</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="/styles/tailwind.css" rel="stylesheet" />
  </head>
  <body class="bg-gray-50 text-gray-900 font-sans">
    <main class="max-w-4xl mx-auto p-6 space-y-8">
      <a href="/" class="text-blue-600 hover:underline text-sm inline-block">← Back to homepage</a>

      {data.logo_url && (
        <img src={data.logo_url} alt={`${data.name} logo`} class="w-full h-64 object-cover rounded-lg shadow-md" />
      )}

      <h1 class="text-4xl font-bold text-orange-600">{data.name}</h1>

      <div class="grid gap-4 text-base bg-white p-4 rounded-lg shadow border">
        <p><strong>📍 Address:</strong> {data.address}</p>
        <p><strong>📞 Phone:</strong> {data.phone_number}</p>
        <p><strong>⏰ Hours:</strong> {data.hours_of_operation}</p>
        <p><strong>⭐ Score:</strong> {data.restaurant_score}/10</p>
        <p><strong>🧠 Best Time to Work Remotely:</strong> {data.best_time_to_work_remotely}</p>
      </div>

      <section class="bg-white p-6 rounded-lg shadow border">
        <h2 class="text-2xl font-semibold mb-4 text-orange-600">💻 Remote Work Features</h2>
        <ul class="grid grid-cols-1 sm:grid-cols-2 gap-3 list-disc pl-5 text-sm">
          <li><strong>Wi-Fi:</strong> {data.remote_work_features?.wi_fi_quality || "Unknown"}</li>
          <li><strong>Outlets:</strong> {data.remote_work_features?.outlet_access || "Unknown"}</li>
          <li><strong>Noise Level:</strong> {data.remote_work_features?.noise_level || "Unknown"}</li>
          <li><strong>Seating Comfort:</strong> {data.remote_work_features?.seating_comfort || "Unknown"}</li>
          <li><strong>Natural Light:</strong> {data.remote_work_features?.natural_light || "Unknown"}</li>
          <li><strong>Stay Duration:</strong> {data.remote_work_features?.stay_duration_friendliness || "Not specified"}</li>
          <li><strong>Food/Drink:</strong> {data.remote_work_features?.food_drink_options || "Unknown"}</li>
          <li><strong>Bathrooms:</strong> {data.remote_work_features?.bathroom_access || "Unknown"}</li>
          <li><strong>Parking:</strong> {data.remote_work_features?.parking_availability || "Unknown"}</li>
        </ul>
      </section>

      {data.tags?.length > 0 && (
        <section>
          <h2 class="text-lg font-medium mb-2 text-orange-600">🏷️ Tags</h2>
          <div class="flex flex-wrap gap-2">
            {data.tags.map(tag => (
              <span class="bg-orange-100 text-orange-700 px-3 py-1 rounded-full text-sm font-medium">{tag}</span>
            ))}
          </div>
        </section>
      )}

      <footer class="mt-8 pt-6 border-t text-center text-sm text-gray-500">
        <p>✨ Powered by NestleIn · <a href="/" class="text-blue-500 hover:underline">Return Home</a></p>
      </footer>
    </main>
  </body>
</html>
